# Bitwarden-backed environment variables (lazy).
#
# `load_secrets` reads a JSON manifest that maps env-var names to Bitwarden
# items, fetches them all in a SINGLE `bw list items` call (bw is slow, so we
# batch), and exports them into the current shell. Nothing runs at startup —
# you call `load_secrets` when you actually want the vars, and you're prompted
# for your master password at most once per shell (the session is reused).
#
# Manifest — default ~/.config/common/secrets.json, override with $BW_SECRETS_FILE.
# It contains NO secrets, only references:
#   {
#     "secrets": [
#       { "env": "GITHUB_TOKEN",   "item": "github-token" },
#       { "env": "OPENAI_API_KEY", "item": "OpenAI",  "field": "api_key" },
#       { "env": "DB_USER",        "item": "prod-db", "field": "username" }
#     ]
#   }
# "field" defaults to "password". Special values "username" / "notes" / "uri"
# read the corresponding login fields; any other value is treated as the name
# of a custom field on the item. Match "item" by item name or by item id.

# Ensure we hold a valid, unlocked session token, reused across calls.
function bw_unlock() {
  if [ -z "$BW_SESSION" ] \
     || ! bw unlock --check --session "$BW_SESSION" >/dev/null 2>&1; then
    local s
    s="$(bw unlock --raw)" || return 1
    export BW_SESSION="$s"
  fi
}

# Drop the cached session (re-locks for this shell).
function bw_lock() {
  bw lock >/dev/null 2>&1
  unset BW_SESSION
}

function load_secrets() {
  local manifest="${BW_SECRETS_FILE:-$HOME/.config/common/secrets.json}"
  [ -f "$manifest" ]      || { echo "load_secrets: no manifest at $manifest" >&2; return 1; }
  command -v bw >/dev/null || { echo "load_secrets: bw not installed" >&2;        return 1; }
  command -v jq >/dev/null || { echo "load_secrets: jq not installed" >&2;        return 1; }

  bw_unlock || return 1

  # Pull every item once; extract each requested secret locally with jq.
  local items
  items="$(bw list items --session "$BW_SESSION")" || {
    echo "load_secrets: failed to list items (session expired? try: bw_lock)" >&2
    return 1
  }

  # Emit  ENV<TAB>base64(value)  lines. base64 keeps multi-line values
  # (e.g. PEM keys) and odd characters intact through the read loop.
  # The vault is piped in on stdin (it's too big to pass as a jq argument).
  local pairs
  pairs="$(printf '%s' "$items" | jq -r --slurpfile cfg "$manifest" '
    . as $items
    | ($cfg[0].secrets // [])[] as $s
    | ($s.field // "password") as $f
    | ($items[] | select(.name == $s.item or .id == $s.item)) as $it
    | ( if   $f == "password" then $it.login.password
        elif $f == "username" then $it.login.username
        elif $f == "notes"    then $it.notes
        elif $f == "uri"      then $it.login.uris[0].uri
        else ($it.fields[]? | select(.name == $f) | .value)
        end ) as $val
    | select($val != null and $val != "")
    | "\($s.env)\t\($val | @base64)"
  ')" || return 1

  local requested count=0 name b64 value resolved=""
  requested="$(jq -r '[.secrets[].env] | length' "$manifest")"

  while IFS=$'\t' read -r name b64; do
    [ -n "$name" ] || continue
    value="$(printf %s "$b64" | base64 -d 2>/dev/null || printf %s "$b64" | base64 -D)"
    export "$name=$value"
    resolved="$resolved $name"
    count=$((count + 1))
  done <<< "$pairs"

  if [ "$count" -lt "${requested:-0}" ]; then
    # Report which entries didn't resolve (wrong item name or empty field).
    local missing="" env
    for env in $(jq -r '.secrets[].env' "$manifest"); do
      case " $resolved " in *" $env "*) ;; *) missing="$missing $env" ;; esac
    done
    echo "load_secrets: exported $count of $requested — unresolved:$missing" >&2
    echo "load_secrets: check item name/field in $manifest (or run: bw sync)" >&2
  else
    echo "load_secrets: exported $count secret(s)" >&2
  fi
}
