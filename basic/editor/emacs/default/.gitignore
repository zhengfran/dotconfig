# Emacs Configuration .gitignore

# Note: init.el is tracked even though it's generated from config.org
# This allows for easy reference and ensures the repo works standalone

# Native compilation cache
eln-cache/

# Package directories
elpa/
straight/
.packages/

# Cache files
.cache/
auto-save-list/
cache/

# Persistent state files
.persp-save
bookmarks
recentf
projectile-bookmarks.eld
projectile.cache

# Recent files and history
var/
etc/
network-security.data

# Auto-save and backup files
*~
\#*\#
.\#*
*.elc

# Org-mode
.org-id-locations
*.org-archive

# Temporary files
tramp
url/
transient/

# Session files
session.*
*.desktop
.last-package-update-day

# Undo tree history
undo/
undo-tree-hist/
.undo-tree-history

# Custom file (often contains machine-specific settings)
custom.el

# LSP and language server files
.lsp-session-*
.lsp-cache/
workspace/

# Org-roam database (optional - uncomment if you want to ignore it)
# org-roam.db

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini

# Emacs temp files
.emacs.desktop
.emacs.desktop.lock
emacs-desktop
emacs-desktop.lock
auto-save-list
ac-comphist.dat
.mc-lists.el

# Quelpa
quelpa/

# Flycheck
flycheck_*.el

# Smex
smex-items

# Request
request/

# VTerm
vterm/

# Rime
librime/
rime/

# Suspicious directory (likely a Windows path that shouldn't be here)
C:*/
